<?xml version="1.0" encoding="UTF-8"?>
<svg width="192" height="192" viewBox="0 0 192 192" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f5e6b8;stop-opacity:1" />
      <stop offset="25%" style="stop-color:#d4a84b;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#b8860b;stop-opacity:1" />
      <stop offset="75%" style="stop-color:#d4a84b;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#f5e6b8;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="192" height="192" fill="#f0f0f0" rx="28.799999999999997" />
  
  <!-- Gold circle background -->
  <circle cx="96" cy="96" r="67.19999999999999" fill="url(#goldGrad)" />
  
  <!-- CCR Text -->
  <text x="96" y="96" 
        text-anchor="middle" 
        dominant-baseline="central"
        font-family="DM Sans, sans-serif" 
        font-size="48" 
        font-weight="700" 
        fill="#ffffff">CCR</text>
</svg>