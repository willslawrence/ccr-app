rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /sermons/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 100 * 1024 * 1024  // 100MB max
        && request.resource.contentType.matches('audio/.*');
    }
  }
}
